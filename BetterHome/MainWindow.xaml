<Window x:Class="BetterHome.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterHome" Icon="/Assets/betterhome.ico" WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized" Background="#020817" Foreground="White" FontFamily="Segoe UI" KeyDown="Window_KeyDown">
  <Window.Resources>
    <Style x:Key="Tiny" TargetType="TextBlock"><Setter Property="FontSize" Value="10"/><Setter Property="Foreground" Value="#B7C1D8"/></Style>
    <Style x:Key="GroupIcon" TargetType="Border"><Setter Property="Width" Value="31"/><Setter Property="Height" Value="31"/><Setter Property="CornerRadius" Value="6"/><Setter Property="Margin" Value="0,0,0,5"/></Style>
    <Style x:Key="RailCard" TargetType="Border" BasedOn="{StaticResource GlassCard}"><Setter Property="Margin" Value="0,0,0,8"/><Setter Property="Padding" Value="13"/></Style>
    <Style x:Key="Progress" TargetType="ProgressBar"><Setter Property="Height" Value="3"/><Setter Property="Background" Value="#24334F"/><Setter Property="Foreground" Value="#4B9CFF"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style x:Key="Toggle" TargetType="ToggleButton"><Setter Property="Width" Value="34"/><Setter Property="Height" Value="18"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton"><Grid><Border x:Name="Track" CornerRadius="9" Background="#465064"/><Ellipse x:Name="Knob" Width="14" Height="14" Fill="#C7CFDD" HorizontalAlignment="Left" Margin="2"/></Grid><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Track" Property="Background" Value="#177DE8"/><Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/><Setter TargetName="Knob" Property="Fill" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="FileHubWindowCircle" TargetType="Button"><Setter Property="Width" Value="28"/><Setter Property="Height" Value="28"/><Setter Property="Margin" Value="2,0"/><Setter Property="Padding" Value="0"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Grid><Ellipse x:Name="Circle" Width="15" Height="15" Fill="{TemplateBinding Background}" Stroke="#55FFFFFF" StrokeThickness="1"/><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Circle" Property="Width" Value="18"/><Setter TargetName="Circle" Property="Height" Value="18"/><Setter TargetName="Circle" Property="Stroke" Value="White"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value=".65"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="GroupScrollBarStyle" TargetType="ScrollBar"><Setter Property="Width" Value="7"/><Setter Property="Background" Value="Transparent"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar"><Grid Background="Transparent"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/></Track.DecreaseRepeatButton><Track.Thumb><Thumb><Thumb.Template><ControlTemplate TargetType="Thumb"><Border x:Name="ThumbBody" Background="#7086A2" CornerRadius="4" Margin="1,2" Opacity=".62"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBody" Property="Background" Value="#4E9BE0"/><Setter TargetName="ThumbBody" Property="Opacity" Value=".95"/></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBody" Property="Background" Value="#2E88D7"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Thumb.Template></Thumb></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/></Track.IncreaseRepeatButton></Track></Grid></ControlTemplate></Setter.Value></Setter></Style>
  </Window.Resources>
  <Grid x:Name="RootGrid">
    <Image Source="Assets/wallpaper.png" Stretch="UniformToFill"/>
    <Rectangle Fill="#25020A1B"/>
    <Grid Margin="24,14,24,12">
      <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="*"/><RowDefinition Height="60"/></Grid.RowDefinitions>
      <Grid.ColumnDefinitions><ColumnDefinition Width="255"/><ColumnDefinition Width="*"/><ColumnDefinition Width="246"/></Grid.ColumnDefinitions>

      <!-- brand -->
      <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Grid Width="25" Height="25" Margin="0,0,8,0"><Ellipse Width="14" Height="23" Fill="#04B4E8" HorizontalAlignment="Left" RenderTransformOrigin=".5,.5"><Ellipse.RenderTransform><RotateTransform Angle="42"/></Ellipse.RenderTransform></Ellipse><Ellipse Width="14" Height="23" Fill="#3544E9" HorizontalAlignment="Right" RenderTransformOrigin=".5,.5"><Ellipse.RenderTransform><RotateTransform Angle="42"/></Ellipse.RenderTransform></Ellipse></Grid>
        <TextBlock Text="BetterHome" FontSize="20" FontWeight="SemiBold"/>
      </StackPanel>
      <Border x:Name="TopControlBar" Visibility="Collapsed" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Right" Background="#D711192C" BorderBrush="#3A7190BE" BorderThickness="1" CornerRadius="12" Padding="7,3">
        <StackPanel Orientation="Horizontal"><TextBlock Text="⌗" FontSize="17" Margin="8,0" VerticalAlignment="Center"/><TextBlock Text="Auto Arrange" FontSize="11" VerticalAlignment="Center"/><ToggleButton x:Name="AutoToggle" Style="{StaticResource Toggle}" IsChecked="True" Margin="8,0,12,0" Click="AutoArrange_Click"/><Rectangle Width="1" Fill="#38506D" Margin="0,4,10,4"/><TextBlock Text="◉" FontSize="14" VerticalAlignment="Center" Margin="0,0,7,0"/><TextBlock Text="Hide Desktop Icons" FontSize="11" VerticalAlignment="Center"/><ToggleButton Style="{StaticResource Toggle}" Margin="8,0,12,0"/><Rectangle Width="1" Fill="#38506D" Margin="0,4,8,4"/><Button Style="{StaticResource IconButton}" Content="▣  Desktop Mode" FontSize="11"/><Rectangle Width="1" Fill="#38506D" Margin="2,4"/><Button Style="{StaticResource IconButton}" Click="Settings_Click" Content="⚙  Settings" FontSize="11"/></StackPanel>
      </Border>

      <!-- left widgets -->
      <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,2,0,0">
        <Border Style="{StaticResource RailCard}" Height="100"><Grid><StackPanel><TextBlock Text="Good evening" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="08:34" FontSize="25" Margin="0,10,0,0"><Run/><Run Text=" PM" FontSize="11"/></TextBlock><TextBlock Text="Monday, May 20, 2024" Style="{StaticResource Tiny}"/></StackPanel><Border HorizontalAlignment="Right" Width="79" CornerRadius="11" Background="#7C173D80"><TextBlock Text="☾" FontSize="47" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E9E8FF"/></Border></Grid></Border>
        <Border Style="{StaticResource RailCard}" Height="195"><StackPanel><TextBlock Text="Calendar" FontSize="13" FontWeight="SemiBold"/><Grid Margin="0,8,0,5"><TextBlock Text="‹" FontSize="18"/><TextBlock Text="May 2024" HorizontalAlignment="Center" FontSize="11"/><TextBlock Text="›" HorizontalAlignment="Right" FontSize="18"/></Grid><UniformGrid Columns="7" Rows="6" TextElement.FontSize="10"><TextBlock Text="Su"/><TextBlock Text="Mo"/><TextBlock Text="Tu"/><TextBlock Text="We"/><TextBlock Text="Th"/><TextBlock Text="Fr"/><TextBlock Text="Sa"/><TextBlock Text="28" Opacity=".55"/><TextBlock Text="29" Opacity=".55"/><TextBlock Text="30" Opacity=".55"/><TextBlock Text="1"/><TextBlock Text="2"/><TextBlock Text="3"/><TextBlock Text="4"/><TextBlock Text="5"/><TextBlock Text="6"/><TextBlock Text="7"/><TextBlock Text="8"/><TextBlock Text="9"/><TextBlock Text="10"/><TextBlock Text="11"/><TextBlock Text="12"/><TextBlock Text="13"/><TextBlock Text="14"/><TextBlock Text="15"/><TextBlock Text="16"/><TextBlock Text="17"/><TextBlock Text="18"/><TextBlock Text="19"/><Border Background="#2688FF" CornerRadius="12" Width="23" Height="23"><TextBlock Text="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="21"/><TextBlock Text="22"/><TextBlock Text="23"/><TextBlock Text="24"/><TextBlock Text="25"/><TextBlock Text="26"/><TextBlock Text="27"/><TextBlock Text="28"/><TextBlock Text="29"/><TextBlock Text="30"/><TextBlock Text="31"/><TextBlock Text="1" Opacity=".55"/></UniformGrid></StackPanel></Border>
        <Border Style="{StaticResource RailCard}" Height="154"><StackPanel><Grid><TextBlock Text="To Do" FontSize="13" FontWeight="SemiBold"/><TextBlock Text="＋" HorizontalAlignment="Right" FontSize="17"/></Grid><TextBlock Text="○  Study for final exam" Margin="0,9,0,0" Style="{StaticResource Tiny}"/><TextBlock Text="○  Finish project presentation" Margin="0,7,0,0" Style="{StaticResource Tiny}"/><TextBlock Text="○  Workout" Margin="0,7,0,0" Style="{StaticResource Tiny}"/><TextBlock Text="○  Read 30 pages" Margin="0,7,0,0" Style="{StaticResource Tiny}"/><TextBlock Text="＋  Add Task" Margin="0,8,0,0" Foreground="#74839F" FontSize="10"/></StackPanel></Border>
        <Border Style="{StaticResource RailCard}" Height="151"><Grid><StackPanel><TextBlock Text="Weather" FontSize="13" FontWeight="SemiBold"/><TextBlock Text="24°" FontSize="31" Margin="0,5,0,0"><Run/><Run Text=" C" FontSize="13"/></TextBlock><TextBlock Text="Clear Sky" Foreground="#8491AB" FontSize="10"/><TextBlock Text="Feels like 24°" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/><UniformGrid Columns="2" Margin="0,10,0,0"><TextBlock Text="♧  Humidity     45%" Style="{StaticResource Tiny}"/><TextBlock Text="◉  Visibility     10 km" Style="{StaticResource Tiny}"/><TextBlock Text="◉  Wind          10 km/h" Style="{StaticResource Tiny}"/><TextBlock Text="☼  UV Index     2 Low" Style="{StaticResource Tiny}"/></UniformGrid></StackPanel><TextBlock Text="☾" FontSize="43" HorizontalAlignment="Right" Margin="0,18,5,0" Foreground="#D9D0FF"/></Grid></Border>
        <Border Style="{StaticResource RailCard}" Height="120"><StackPanel><TextBlock Text="System" FontSize="13" FontWeight="SemiBold"/><Grid Margin="0,7,0,2"><TextBlock Text="CPU Usage" Style="{StaticResource Tiny}"/><TextBlock Text="18%" Style="{StaticResource Tiny}" HorizontalAlignment="Right"/></Grid><ProgressBar Style="{StaticResource Progress}" Value="18"/><Grid Margin="0,7,0,2"><TextBlock Text="RAM Usage" Style="{StaticResource Tiny}"/><TextBlock Text="46%" Style="{StaticResource Tiny}" HorizontalAlignment="Right"/></Grid><ProgressBar Style="{StaticResource Progress}" Value="46" Foreground="#80D1FF"/><Grid Margin="0,7,0,2"><TextBlock Text="Disk (C:)" Style="{StaticResource Tiny}"/><TextBlock Text="62%" Style="{StaticResource Tiny}" HorizontalAlignment="Right"/></Grid><ProgressBar Style="{StaticResource Progress}" Value="62" Foreground="#8E65FF"/></StackPanel></Border>
      </StackPanel>

      <!-- right groups -->
      <Canvas Grid.Row="1" Grid.Column="2" x:Name="GroupsCanvas" Margin="0,7,0,0">
        <Border x:Name="WorkGroup" Style="{StaticResource GlassCard}" Canvas.Top="0" Width="246" Height="155" MouseLeftButtonDown="DragPanel_MouseDown" MouseMove="DragPanel_MouseMove" MouseLeftButtonUp="DragPanel_MouseUp"><StackPanel><TextBlock Text="●  Work" FontSize="13" FontWeight="SemiBold" Foreground="#F3F5FF"/><UniformGrid Columns="3" Margin="0,14,0,0"><StackPanel><Border Style="{StaticResource GroupIcon}" Background="#08A9E8"><TextBlock Text="▰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="This PC" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><Border Style="{StaticResource GroupIcon}" Background="#FFB62B"><TextBlock Text="▰" FontSize="19" HorizontalAlignment="Center"/></Border><TextBlock Text="Documents" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><Border Style="{StaticResource GroupIcon}" Background="#FFAD21"><TextBlock Text="▰" FontSize="19" HorizontalAlignment="Center"/></Border><TextBlock Text="Project Files" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><Border Style="{StaticResource GroupIcon}" Background="#B9C9D8"><TextBlock Text="♻" FontSize="19" HorizontalAlignment="Center"/></Border><TextBlock Text="Recycle Bin" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel></UniformGrid></StackPanel></Border>
        <Border x:Name="AppsGroup" Style="{StaticResource GlassCard}" Canvas.Top="163" Width="246" Height="168" MouseLeftButtonDown="DragPanel_MouseDown" MouseMove="DragPanel_MouseMove" MouseLeftButtonUp="DragPanel_MouseUp"><StackPanel><TextBlock Text="●  Apps" FontSize="13" FontWeight="SemiBold"/><UniformGrid Columns="4" Margin="0,13,0,0"><StackPanel><TextBlock Text="◉" FontSize="28" Foreground="#FBC22F" HorizontalAlignment="Center"/><TextBlock Text="Chrome" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="●" FontSize="28" Foreground="#1BD566" HorizontalAlignment="Center"/><TextBlock Text="Spotify" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="❯" FontSize="28" Foreground="#15A9F3" HorizontalAlignment="Center"/><TextBlock Text="VS Code" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="N" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Text="Notion" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="Ps" FontSize="22" Foreground="#18A7EE" HorizontalAlignment="Center"/><TextBlock Text="Photoshop" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="●" FontSize="25" Foreground="#7568FF" HorizontalAlignment="Center"/><TextBlock Text="Discord" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="F" FontSize="24" Foreground="#F15C61" HorizontalAlignment="Center"/><TextBlock Text="Figma" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel></UniformGrid></StackPanel></Border>
        <Border x:Name="FoldersGroup" Style="{StaticResource GlassCard}" Canvas.Top="339" Width="246" Height="155" MouseLeftButtonDown="DragPanel_MouseDown" MouseMove="DragPanel_MouseMove" MouseLeftButtonUp="DragPanel_MouseUp"><StackPanel><TextBlock Text="●  Folders" FontSize="13" FontWeight="SemiBold"/><UniformGrid Columns="3" Margin="0,12,0,0"><StackPanel><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="Projects" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="University" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="Personal" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,10,0,0"><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="Notes" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,10,0,0"><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="Resources" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,10,0,0"><TextBlock Text="▰" FontSize="28" Foreground="#FFB52B" HorizontalAlignment="Center"/><TextBlock Text="Archive" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel></UniformGrid></StackPanel></Border>
        <Border x:Name="GamesGroup" Style="{StaticResource GlassCard}" Canvas.Top="502" Width="246" Height="165" MouseLeftButtonDown="DragPanel_MouseDown" MouseMove="DragPanel_MouseMove" MouseLeftButtonUp="DragPanel_MouseUp"><StackPanel><TextBlock Text="●  Games" FontSize="13" FontWeight="SemiBold"/><UniformGrid Columns="3" Margin="0,12,0,0"><StackPanel><TextBlock Text="◉" FontSize="26" Foreground="#D4E9FF" HorizontalAlignment="Center"/><TextBlock Text="Steam" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="EPIC" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Text="Epic Games" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel><TextBlock Text="▦" FontSize="27" Foreground="#67A64B" HorizontalAlignment="Center"/><TextBlock Text="Minecraft" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="✦" FontSize="25" Foreground="#C7DEFF" HorizontalAlignment="Center"/><TextBlock Text="Genshin Impact" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="V" FontSize="24" Foreground="#FA465A" HorizontalAlignment="Center"/><TextBlock Text="Valorant" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel><StackPanel Margin="0,12,0,0"><TextBlock Text="EA" FontSize="20" Foreground="#FF5D26" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Text="EA App" Style="{StaticResource Tiny}" TextAlignment="Center"/></StackPanel></UniformGrid></StackPanel></Border>
      </Canvas>

      <!-- file hub -->
      <Canvas Grid.Row="1" Grid.Column="1" x:Name="CenterCanvas">
        <Border x:Name="FileHub" Canvas.Left="10" Canvas.Top="10" Width="640" Height="430" Background="#F20A182C" BorderBrush="#526C88A9" BorderThickness="1" CornerRadius="14" MouseLeftButtonDown="DragPanel_MouseDown" MouseMove="DragPanel_MouseMove" MouseLeftButtonUp="DragPanel_MouseUp">
          <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="8" Opacity=".55"/></Border.Effect>
          <Grid><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/><RowDefinition Height="0"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#D90C1A2E" CornerRadius="14,14,0,0" Padding="18,0"><Grid><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Border Width="34" Height="34" CornerRadius="7" Background="#1F7FDF" Margin="0,0,12,0"><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel VerticalAlignment="Center"><TextBlock Text="File Hub" FontWeight="SemiBold" FontSize="14"/><TextBlock Text="BetterHome" Foreground="#8495B1" FontSize="10" Margin="0,2,0,0"/></StackPanel></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource FileHubWindowCircle}" Background="#F6C344" ToolTip="Minimize" Click="MinimizeFileHub_Click"/><Button Style="{StaticResource FileHubWindowCircle}" Background="#38C978" ToolTip="Maximize or restore" Click="MaximizeFileHub_Click"/><Button Style="{StaticResource FileHubWindowCircle}" Background="#F05B61" ToolTip="Close" Click="CloseFileHub_Click"/></StackPanel></Grid></Border>
            <Grid Grid.Row="1" Margin="9"><Grid.ColumnDefinitions><ColumnDefinition Width="98"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Border Background="#422D3A5C" CornerRadius="9" Padding="8"><StackPanel><TextBlock Text="Quick Access" Style="{StaticResource Tiny}" Margin="0,0,0,8"/><Border Background="#314E7D" CornerRadius="6" Padding="5"><TextBlock Text="▰  Desktop" FontSize="10"/></Border><TextBlock Text="↓  Downloads" FontSize="10" Margin="5,9" Foreground="#42C998"/><TextBlock Text="▣  Documents" FontSize="10" Margin="5,4"/><TextBlock Text="▧  Pictures" FontSize="10" Margin="5,4" Foreground="#4AB8FF"/><TextBlock Text="●  Music" FontSize="10" Margin="5,4" Foreground="#FF6C79"/><TextBlock Text="▶  Videos" FontSize="10" Margin="5,4" Foreground="#9B5CFF"/></StackPanel></Border>
              <Border Grid.Column="1" Background="#2D1B2947" CornerRadius="9" Padding="10" Margin="8,0,0,0"><StackPanel><Grid><TextBlock Text="Recent Files" FontSize="11"/><TextBlock Text="View all" Foreground="#3697FF" HorizontalAlignment="Right" FontSize="9"/></Grid><Grid Margin="0,11,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="57"/></Grid.ColumnDefinitions><TextBlock Text="▣" Foreground="#FF545B"/><TextBlock Grid.Column="1" Text="Project Proposal.pdf" FontSize="9"/><TextBlock Grid.Column="2" Text="Just now" Style="{StaticResource Tiny}"/><TextBlock Grid.Column="3" Text="Documents" Style="{StaticResource Tiny}"/></Grid><Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="57"/></Grid.ColumnDefinitions><TextBlock Text="X" Foreground="#4ECC76"/><TextBlock Grid.Column="1" Text="Budget 2024.xlsx" FontSize="9"/><TextBlock Grid.Column="2" Text="2h ago" Style="{StaticResource Tiny}"/><TextBlock Grid.Column="3" Text="Documents" Style="{StaticResource Tiny}"/></Grid><Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="57"/></Grid.ColumnDefinitions><TextBlock Text="◇" Foreground="#FFB83E"/><TextBlock Grid.Column="1" Text="BetterHome Design.sketch" FontSize="9"/><TextBlock Grid.Column="2" Text="5h ago" Style="{StaticResource Tiny}"/><TextBlock Grid.Column="3" Text="Designs" Style="{StaticResource Tiny}"/></Grid><Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="57"/></Grid.ColumnDefinitions><TextBlock Text="▤"/><TextBlock Grid.Column="1" Text="Meeting Notes.txt" FontSize="9"/><TextBlock Grid.Column="2" Text="Yesterday" Style="{StaticResource Tiny}"/><TextBlock Grid.Column="3" Text="Documents" Style="{StaticResource Tiny}"/></Grid><Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition/><ColumnDefinition Width="54"/><ColumnDefinition Width="57"/></Grid.ColumnDefinitions><TextBlock Text="P" Foreground="#FF6648"/><TextBlock Grid.Column="1" Text="Presentation.pptx" FontSize="9"/><TextBlock Grid.Column="2" Text="Yesterday" Style="{StaticResource Tiny}"/><TextBlock Grid.Column="3" Text="Documents" Style="{StaticResource Tiny}"/></Grid></StackPanel></Border>
            </Grid>
            <Border Grid.Row="2" Margin="9,0,9,9" Background="#55283A63" CornerRadius="8"><UniformGrid Columns="4"><Button Style="{StaticResource IconButton}" Content="▱  New Folder" FontSize="10"/><Button Style="{StaticResource IconButton}" Content="♧  Upload" FontSize="10"/><Button Style="{StaticResource IconButton}" Content="⇅  Sort" FontSize="10"/><Button Style="{StaticResource IconButton}" Content="▦  View" FontSize="10"/></UniformGrid></Border>
          </Grid>
        </Border>
      </Canvas>

      <!-- dock and tray -->
      <Border x:Name="DockBar" Grid.Row="2" Grid.Column="1" Width="600" Height="50" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="#DA201D36" BorderBrush="#5E7F87AA" BorderThickness="1" CornerRadius="16"><UniformGrid x:Name="DockItemsHost" Columns="8" Margin="70,0"><Button Style="{StaticResource IconButton}" Content="⊞" Foreground="#14A8FF" FontSize="28"/><Button Style="{StaticResource IconButton}" Content="⌕" FontSize="29"/><Button Style="{StaticResource IconButton}" Content="▣" Foreground="#B9C7DD" FontSize="24" Click="ShowFileHub_Click"/><Button Style="{StaticResource IconButton}" Content="◉" Foreground="#F4C028" FontSize="24"/><Button Style="{StaticResource IconButton}" Content="❯" Foreground="#13A9F2" FontSize="27"/><Button Style="{StaticResource IconButton}" Content="●" Foreground="#1ED760" FontSize="25"/><Button Style="{StaticResource IconButton}" Content="⚙" Foreground="#A8C0DB" FontSize="23" Click="Settings_Click"/><Button Style="{StaticResource IconButton}" Content="♜" Foreground="#ADC0CF" FontSize="22"/></UniformGrid></Border>
      <StackPanel x:Name="TrayArea" Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TrayArea_Click" ToolTip="Open BetterHome Smart Tray">
        <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
        <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
        <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
        <TextBlock Text="&#xE850;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" Margin="0,0,20,0"/>
        <StackPanel><TextBlock x:Name="TrayClockText" Text="08:34 PM" HorizontalAlignment="Right" FontSize="12"/><TextBlock x:Name="TrayDateText" Text="5/20/2024" HorizontalAlignment="Right" FontSize="11" Foreground="#A7B3CB"/></StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
