<Window x:Class="BetterHome.Views.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="BetterHome Settings" Icon="/Assets/betterhome.ico" Width="520" Height="620" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Foreground="White" ResizeMode="NoResize">
  <Window.Resources>
    <Style TargetType="ToggleButton"><Setter Property="Width" Value="40"/><Setter Property="Height" Value="22"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton"><Grid><Border x:Name="Track" Background="#45526A" CornerRadius="11"/><Ellipse x:Name="Knob" Width="18" Height="18" Fill="#CBD3E1" HorizontalAlignment="Left" Margin="2"/></Grid><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Track" Property="Background" Value="#2587E8"/><Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/><Setter TargetName="Knob" Property="Fill" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="Row" TargetType="Border"><Setter Property="Background" Value="#18243D"/><Setter Property="CornerRadius" Value="11"/><Setter Property="Padding" Value="14"/><Setter Property="Margin" Value="0,0,0,8"/></Style>
    <Style TargetType="Button"><Setter Property="Background" Value="#253A5F"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#456B9B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,6"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#315080"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBorder" Property="Background" Value="#1F70C8"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="TextBox"><Setter Property="Background" Value="#22334F"/><Setter Property="Foreground" Value="White"/><Setter Property="CaretBrush" Value="White"/><Setter Property="BorderBrush" Value="#466A96"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="8,4"/></Style>
    <Style TargetType="ComboBox"><Setter Property="Background" Value="#22334F"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#466A96"/><Setter Property="Padding" Value="7,3"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><ToggleButton Focusable="False" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border Background="#22334F" BorderBrush="#466A96" BorderThickness="1" CornerRadius="5"><Grid><ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" Margin="9,3,25,3" HorizontalAlignment="Left" VerticalAlignment="Center"/><TextBlock Text="⌄" Foreground="White" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center"/></Grid></Border></ControlTemplate></ToggleButton.Template></ToggleButton><Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True"><Border Background="#18243D" BorderBrush="#466A96" BorderThickness="1" CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}"><ScrollViewer><ItemsPresenter/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ComboBoxItem"><Setter Property="Background" Value="#18243D"/><Setter Property="Foreground" Value="White"/><Setter Property="Padding" Value="8,5"/></Style>
  </Window.Resources>
  <Border Background="#F210182C" BorderBrush="#55759AD0" BorderThickness="1" CornerRadius="16" Padding="26">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
      <StackPanel><TextBlock Text="BetterHome Settings" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Windows integration and appearance" Foreground="#9FAAC0" Margin="0,5,0,0"/></StackPanel>
      <ScrollViewer Grid.Row="1" Margin="0,18,0,8" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"><StackPanel Margin="0,0,6,0">
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Start with Windows" FontSize="14"/><TextBlock Text="Launch when you sign in" Foreground="#8C99B3" FontSize="11"/></StackPanel><ToggleButton x:Name="StartToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Hide desktop icons on launch" FontSize="14"/><TextBlock Text="Uses the safe Windows desktop command" Foreground="#8C99B3" FontSize="11"/></StackPanel><ToggleButton x:Name="HideIconsToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Auto arrange on launch" FontSize="14"/><TextBlock Text="Restore the default panel layout" Foreground="#8C99B3" FontSize="11"/></StackPanel><ToggleButton x:Name="AutoToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Show Widgets" FontSize="14"/><ToggleButton x:Name="WidgetsToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Show Dock" FontSize="14"/><ToggleButton x:Name="DockToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Show File Hub on launch" FontSize="14"/><ToggleButton x:Name="FileHubToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Weather location" FontSize="14"/><TextBlock Text="Cairo coordinates are used in this version" Foreground="#8C99B3" FontSize="11"/></StackPanel><TextBox x:Name="WeatherLocationBox" Width="130" Height="28" HorizontalAlignment="Right" VerticalContentAlignment="Center"/></Grid></Border>
        <TextBlock Text="Prayer Times" FontSize="13" FontWeight="SemiBold" Foreground="#64B8FF" Margin="2,8,0,7"/>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Enable prayer widget" FontSize="14"/><ToggleButton x:Name="PrayerWidgetToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Prayer location" FontSize="14"/><TextBlock Text="City, Country" Foreground="#8C99B3" FontSize="11"/></StackPanel><TextBox x:Name="PrayerLocationBox" Width="150" Height="28" HorizontalAlignment="Right" VerticalContentAlignment="Center"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Calculation method" FontSize="14"/><ComboBox x:Name="PrayerMethodBox" Width="185" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="Egyptian General Authority"/><ComboBoxItem Content="Muslim World League"/><ComboBoxItem Content="Umm Al-Qura"/></ComboBox></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Reminder before prayer" FontSize="14"/><ComboBox x:Name="PrayerReminderBox" Width="110" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="Off" Tag="0"/><ComboBoxItem Content="5 min" Tag="5"/><ComboBoxItem Content="10 min" Tag="10"/><ComboBoxItem Content="15 min" Tag="15"/></ComboBox></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Notification sound" FontSize="14"/><ToggleButton x:Name="PrayerSoundToggle" HorizontalAlignment="Right"/></Grid></Border>
        <TextBlock Text="Live Wallpaper" FontSize="13" FontWeight="SemiBold" Foreground="#64B8FF" Margin="2,8,0,7"/>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Enable live wallpaper" FontSize="14"/><ToggleButton x:Name="LiveWallpaperToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Wallpaper type" FontSize="14"/><ComboBox x:Name="WallpaperTypeBox" Width="155" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="Static"/><ComboBoxItem Content="Video"/><ComboBoxItem Content="Animated gradient"/><ComboBoxItem Content="WebView animation"/></ComboBox></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Quality" FontSize="14"/><ComboBox x:Name="WallpaperQualityBox" Width="110" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="Low"/><ComboBoxItem Content="Medium"/><ComboBoxItem Content="High"/></ComboBox></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Pause on battery" FontSize="14"/><ToggleButton x:Name="PauseBatteryToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Pause for fullscreen apps" FontSize="14"/><ToggleButton x:Name="PauseFullscreenToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Pause on high CPU" FontSize="14"/><ToggleButton x:Name="PauseCpuToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Theme" FontSize="14"/><TextBlock Text="Light and System are placeholders" Foreground="#8C99B3" FontSize="11"/></StackPanel><ComboBox x:Name="ThemeBox" Width="110" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="Dark"/><ComboBoxItem Content="Light"/><ComboBoxItem Content="System"/></ComboBox></Grid></Border>
        <TextBlock Text="Premium Features" FontSize="13" FontWeight="SemiBold" Foreground="#64B8FF" Margin="2,8,0,7"/>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Dynamic Island" FontSize="14"/><ToggleButton x:Name="DynamicIslandToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="App Drawer" FontSize="14"/><ToggleButton x:Name="AppDrawerToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Open Apps Overview" FontSize="14"/><ToggleButton x:Name="OpenAppsToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Running Apps Strip" FontSize="14"/><ToggleButton x:Name="RunningStripToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Mini Player" FontSize="14"/><ToggleButton x:Name="MiniPlayerToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Screen Edge Dock" FontSize="14"/><ToggleButton x:Name="EdgeDockToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Assistant Bubble" FontSize="14"/><ToggleButton x:Name="AssistantToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Smart Tray" FontSize="14"/><ToggleButton x:Name="SmartTrayToggle" HorizontalAlignment="Right"/></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><TextBlock Text="Confirm before closing apps" FontSize="14"/><ToggleButton x:Name="ConfirmCloseToggle" HorizontalAlignment="Right"/></Grid></Border>
        <TextBlock Text="Text &amp; Scale" FontSize="13" FontWeight="SemiBold" Foreground="#64B8FF" Margin="2,8,0,7"/>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="Interface font size" FontSize="14"/><TextBlock Text="Applies to menus and general controls" Foreground="#8C99B3" FontSize="11"/></StackPanel><ComboBox x:Name="UiFontSizeBox" Width="90" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="14"/><ComboBoxItem Content="16"/></ComboBox></Grid></Border>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="File Hub font size" FontSize="14"/><TextBlock Text="Files, navigation and toolbar" Foreground="#8C99B3" FontSize="11"/></StackPanel><ComboBox x:Name="FileHubFontSizeBox" Width="90" Height="30" HorizontalAlignment="Right"><ComboBoxItem Content="10"/><ComboBoxItem Content="12"/><ComboBoxItem Content="14"/><ComboBoxItem Content="16"/></ComboBox></Grid></Border>
        <TextBlock Text="About" FontSize="13" FontWeight="SemiBold" Foreground="#64B8FF" Margin="2,12,0,7"/>
        <Border Style="{StaticResource Row}"><Grid><StackPanel><TextBlock Text="BetterHome" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="Developed by ziyad3laa" Foreground="#B9C7DD" FontSize="12" Margin="0,6,0,0"/><TextBlock Text="Version 1.0-beta" Foreground="#7FAEE3" FontSize="11" Margin="0,4,0,0"/><TextBlock Text="Open-source Windows desktop shell" Foreground="#8C99B3" FontSize="10" Margin="0,7,0,0"/></StackPanel></Grid></Border>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,0"><Button Content="Reset layout" Width="110" Height="32" Click="ResetLayout_Click"/><Button Content="Reset all settings" Width="130" Height="32" Margin="10,0,0,0" Click="ResetAll_Click"/></StackPanel>
      </StackPanel></ScrollViewer>
      <Border Grid.Row="2" BorderBrush="#334D72" BorderThickness="0,1,0,0" Padding="0,14,0,0"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0" Click="Cancel_Click"/><Button Content="Save &amp; Close" Width="110" Height="34" Click="Done_Click" Background="#237FDB" Foreground="White" BorderThickness="0"/></StackPanel></Border>
    </Grid>
  </Border>
</Window>
