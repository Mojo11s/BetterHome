<UserControl x:Class="BetterHome.Views.FileHubView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent" Foreground="#DCE7F8">
  <UserControl.Resources>
    <Style x:Key="FileHubCommandButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="#CFDAEC"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="7,5"/><Setter Property="Margin" Value="1,0"/><Setter Property="FontSize" Value="11"/><Setter Property="HorizontalContentAlignment" Value="Center"/><Setter Property="MinHeight" Value="30"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="#263D60"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="B" Property="Background" Value="#315D91"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value=".35"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="FileHubSidebarItemStyle" TargetType="Button" BasedOn="{StaticResource FileHubCommandButtonStyle}"><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Margin" Value="0,2"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="Transparent"/></Style>
    <Style x:Key="FileHubTabStyle" TargetType="Button" BasedOn="{StaticResource FileHubCommandButtonStyle}"><Setter Property="Background" Value="#1A2D4A"/><Setter Property="BorderBrush" Value="#356EA9"/><Setter Property="BorderThickness" Value="1,1,1,0"/><Setter Property="Padding" Value="13,7"/><Setter Property="Cursor" Value="Hand"/></Style>
    <Style TargetType="TextBox"><Setter Property="Background" Value="#101D32"/><Setter Property="Foreground" Value="#E3ECFA"/><Setter Property="CaretBrush" Value="White"/><Setter Property="BorderBrush" Value="#263E5F"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,5"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"><ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="GridViewColumnHeader"><Setter Property="Background" Value="#101D32"/><Setter Property="Foreground" Value="#C8D5E7"/><Setter Property="BorderBrush" Value="#263D5C"/><Setter Property="BorderThickness" Value="0,0,1,1"/><Setter Property="Padding" Value="10,7"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="GridViewColumnHeader"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ListViewItem"><Setter Property="Foreground" Value="#D8E3F3"/><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="4,5"/><Setter Property="Cursor" Value="Hand"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="BorderBrush" Value="#162B48"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E3555"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#264D7D"/><Setter Property="BorderBrush" Value="#337BC0"/></Trigger></Style.Triggers></Style>
    <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#D8E3F3"/><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="4"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E3555"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#264D7D"/></Trigger></Style.Triggers></Style>
    <Style TargetType="ScrollBar"><Setter Property="Width" Value="9"/><Setter Property="Height" Value="9"/><Setter Property="Background" Value="#101C30"/><Setter Property="Foreground" Value="#526B88"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar"><Grid Background="{TemplateBinding Background}"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton Background="Transparent" BorderThickness="0" Command="ScrollBar.PageUpCommand"/></Track.DecreaseRepeatButton><Track.Thumb><Thumb Background="#536D8D"><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="1"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton Background="Transparent" BorderThickness="0" Command="ScrollBar.PageDownCommand"/></Track.IncreaseRepeatButton></Track></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <DataTemplate x:Key="GridItem"><StackPanel Width="105" Margin="7" ToolTip="{Binding FullPath}"><Image Source="{Binding Icon}" Width="46" Height="46"/><TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/></StackPanel></DataTemplate>
    <DataTemplate x:Key="ListItem"><StackPanel Orientation="Horizontal" Margin="4"><Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,9,0"/><TextBlock Text="{Binding Name}" VerticalAlignment="Center"/></StackPanel></DataTemplate>
    <ItemsPanelTemplate x:Key="WrapItems"><WrapPanel/></ItemsPanelTemplate>
  </UserControl.Resources>

  <Grid Margin="7" TextElement.FontSize="12"><Grid.RowDefinitions><RowDefinition Height="47"/><RowDefinition Height="43"/><RowDefinition Height="*"/><RowDefinition Height="39"/></Grid.RowDefinitions>
    <Border Background="#B9122036" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="8" Padding="6"><StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
      <Button Style="{StaticResource FileHubCommandButtonStyle}" Content="←  Back" ToolTip="Back" Click="Back_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="→  Forward" ToolTip="Forward" Click="Forward_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="↑  Up" ToolTip="Parent folder" Click="Up_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="⟳  Refresh" ToolTip="Refresh" Click="Refresh_Click"/><Border Width="1" Background="#36506E" Margin="7,3"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="▱  New Folder" ToolTip="New Folder" Click="NewFolder_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="▣  Copy" ToolTip="Copy" Click="Copy_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="✂  Cut" ToolTip="Cut" Click="Cut_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="▤  Paste" ToolTip="Paste" Click="Paste_Click"/><Border Width="1" Background="#36506E" Margin="7,3"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="✎  Rename" ToolTip="Rename" Click="Rename_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Foreground="#FF646B" Content="♲  Delete" ToolTip="Move to Recycle Bin" Click="Delete_Click"/><Border Width="1" Background="#36506E" Margin="7,3"/><Button x:Name="ViewButton" Style="{StaticResource FileHubCommandButtonStyle}" Content="☷  Details" ToolTip="Change view" Click="View_Click"/>
    </StackPanel></Border>

    <Grid Grid.Row="1" Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="280"/></Grid.ColumnDefinitions>
      <Border Background="#B9122036" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="8" Padding="8"><Grid><TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center"/><TextBox x:Name="AddressBox" Visibility="Collapsed" Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}" KeyDown="Address_KeyDown"/><StackPanel x:Name="BreadcrumbHost" Orientation="Horizontal" Margin="32,0,0,0" VerticalAlignment="Center"/></Grid></Border>
      <Grid Grid.Column="1" Margin="7,0,0,0"><TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="34,5,10,5"/><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="11,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/><TextBlock Text="Search files" Foreground="#71839E" Margin="35,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Grid>
    </Grid>

    <Grid Grid.Row="2" Margin="0,7,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="205"/><ColumnDefinition Width="*"/><ColumnDefinition Width="270"/></Grid.ColumnDefinitions>
      <Border Background="#B9101D32" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="9" Padding="8" Margin="0,0,6,0"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel x:Name="NavigationHost"/></ScrollViewer></Border>
      <Border Grid.Column="1" Background="#A80E1B30" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="9" Margin="0,0,6,0"><Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="#A9152843" BorderBrush="#263E5F" BorderThickness="0,0,0,1" CornerRadius="9,9,0,0"><StackPanel x:Name="TabHost" Orientation="Horizontal" VerticalAlignment="Bottom"><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="＋" ToolTip="Open another folder tab" Click="NewTab_Click"/></StackPanel></Border>
        <Grid Grid.Row="1"><ListView x:Name="DetailsList" FontSize="12" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" Foreground="White" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="Items_DoubleClick" SelectionChanged="Selection_Changed" PreviewMouseMove="Items_MouseMove" AllowDrop="True" Drop="Items_Drop"><ListView.ContextMenu><ContextMenu><MenuItem Header="Open" Click="Open_Click"/><MenuItem Header="Open in Windows Explorer" Click="OpenLocation_Click"/><Separator/><MenuItem Header="Rename" Click="Rename_Click"/><MenuItem Header="Copy" Click="Copy_Click"/><MenuItem Header="Cut" Click="Cut_Click"/><MenuItem Header="Delete" Click="Delete_Click"/><Separator/><MenuItem Header="Properties" Click="Properties_Click"/></ContextMenu></ListView.ContextMenu><ListView.View><GridView><GridViewColumn Width="34"><GridViewColumn.CellTemplate><DataTemplate><Image Source="{Binding Icon}" Width="20" Height="20"/></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn><GridViewColumn Header="Name" Width="205" DisplayMemberBinding="{Binding Name}"/><GridViewColumn Header="Date Modified" Width="140" DisplayMemberBinding="{Binding DateModified, StringFormat={}{0:g}}"/><GridViewColumn Header="Type" Width="105" DisplayMemberBinding="{Binding Type}"/><GridViewColumn Header="Size" Width="70" DisplayMemberBinding="{Binding SizeText}"/></GridView></ListView.View></ListView>
          <ListBox x:Name="AlternateList" Visibility="Collapsed" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" Foreground="White" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch" MouseDoubleClick="Items_DoubleClick" SelectionChanged="Selection_Changed" PreviewMouseMove="Items_MouseMove" AllowDrop="True" Drop="Items_Drop"/></Grid>
      </Grid></Border>
      <Border Grid.Column="2" Background="#B9101D32" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="9" Padding="18"><Grid><StackPanel x:Name="EmptyDetails" VerticalAlignment="Center"><TextBlock Text="▱" FontSize="48" Foreground="#54769D" HorizontalAlignment="Center"/><TextBlock Text="Select an item to see details" Foreground="#8498B4" HorizontalAlignment="Center" Margin="0,12,0,0"/></StackPanel><StackPanel x:Name="DetailsPane" Visibility="Collapsed"><Image x:Name="PreviewIcon" Width="72" Height="72" HorizontalAlignment="Center"/><TextBlock x:Name="DetailName" FontSize="17" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,13,0,2"/><TextBlock x:Name="DetailType" Foreground="#8192AD" TextAlignment="Center"/><Border Height="1" Background="#314762" Margin="0,18,0,15"/><TextBlock Text="Details" FontWeight="SemiBold" Margin="0,0,0,11"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="145"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Location" Foreground="#8293AD" Margin="0,3"/><TextBlock Text="Size" Foreground="#8293AD" Margin="0,7"/><TextBlock Text="Modified" Foreground="#8293AD" Margin="0,7"/><TextBlock Text="Created" Foreground="#8293AD" Margin="0,7"/></StackPanel><StackPanel Grid.Column="1"><TextBlock x:Name="DetailLocation" TextTrimming="CharacterEllipsis" Margin="0,3"/><TextBlock x:Name="DetailSize" Margin="0,7"/><TextBlock x:Name="DetailModified" Margin="0,7"/><TextBlock x:Name="DetailCreated" Margin="0,7"/></StackPanel></Grid><Button Style="{StaticResource FileHubCommandButtonStyle}" Background="#28558D" Content="▱  Open" Margin="0,18,0,4" Click="Open_Click"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="⇧  Share" ToolTip="Open Windows share options" Click="Share_Click"/><Button Grid.Column="1" Style="{StaticResource FileHubCommandButtonStyle}" Content="⌖  Pin" ToolTip="Pin to Quick Access" Click="Pin_Click"/></Grid></StackPanel></Grid></Border>
    </Grid>

    <Border Grid.Row="3" Background="#B9122036" BorderBrush="#263E5F" BorderThickness="1" CornerRadius="8" Padding="12,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="320"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="{Binding Items.Count, StringFormat={}{0} items}" VerticalAlignment="Center" Foreground="#A9B8CC"/><TextBlock x:Name="SelectionStatus" Grid.Column="1" Text="0 selected" VerticalAlignment="Center" Foreground="#8FA3BE"/><StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock x:Name="DriveText" Text="Drive" Margin="0,0,10,0"/><ProgressBar x:Name="DriveBar" Width="140" Height="5" Minimum="0" Maximum="100" Background="#263A55" Foreground="#3C95ED" BorderThickness="0"/><TextBlock x:Name="FreeSpaceText" Margin="10,0,0,0" Foreground="#8FA3BE"/></StackPanel><TextBlock Grid.Column="3" Text="{Binding CurrentPath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#8FA3BE"/><StackPanel Grid.Column="4" Orientation="Horizontal"><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="▦" ToolTip="Grid view" Click="GridView_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="☰" ToolTip="List view" Click="ListView_Click"/><Button Style="{StaticResource FileHubCommandButtonStyle}" Content="☷" ToolTip="Details view" Click="DetailsView_Click"/></StackPanel></Grid></Border>
  </Grid>
</UserControl>
